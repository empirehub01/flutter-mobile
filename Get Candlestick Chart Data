GET /market/chart/:symbol

Query Parameters:
  interval: string (1m, 5m, 15m, 1h, 4h, 1d, 1w, 1M)
  limit: number (default: 100, max: 500)
  startTime: number (optional, unix timestamp)
  endTime: number (optional, unix timestamp)

